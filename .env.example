# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL / Supabase Transaction Pooler URI
# Get it from: Supabase Dashboard → Settings → Database → Transaction pooler URI
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Server-only: Supabase URL for Storage uploads (optional; falls back to VITE_SUPABASE_URL)
# SUPABASE_URL=https://<project-ref>.supabase.co
