# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL / Supabase Transaction Pooler URI
# Get it from: Supabase Dashboard → Settings → Database → Transaction pooler URI
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# ─── Auth (session + seed) ───────────────────────────────────────────────────
# Session secret (change in production)
SESSION_SECRET=your-random-secret-at-least-32-chars
# Optional: first-run admin user (only used when no user exists)
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=your-secure-password

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
# Must be service_role (not anon), same project as VITE_SUPABASE_URL, no spaces/newlines
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Server-only: Supabase URL for Storage uploads (optional; falls back to VITE_SUPABASE_URL)
# SUPABASE_URL=https://<project-ref>.supabase.co
